{
  "buildCommand": "npm install --prefix ./frontend && npm run build --prefix ./frontend",
  "outputDirectory": "./frontend/build",
  "public": true,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
